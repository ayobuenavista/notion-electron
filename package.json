{
  "name": "notion-electron",
  "version": "2.0.0",
  "main": "index.mjs",
  "type": "module",
  "desktopName": "notion-electron.desktop",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "start": "APPIMAGE=/ electron .",
    "make": "node ./dev/pack-linux.mjs && chmod -R 777 ./dist/notion-electron-linux-x64/",
    "pack": "electron-builder --linux",
    "check:packaged-sharp": "node ./dev/check-packaged-sharp-linux-x64.mjs",
    "install-desktop-file": "desktop-file-install --dir=$HOME/.local/share/applications ./notion-electron.desktop",
    "dev": "node ./dev/release-server.mjs",
    "flatpak-lint": "./dev/flatpak/lint.sh",
    "flatpak-build": "./dev/flatpak/build.sh",
    "flatpak-test": "./dev/flatpak/test.sh",
    "flatpak-clean": "./dev/flatpak/clean.sh",
    "snap-build": "./dev/snap/build.sh",
    "snap-upload": "snapcraft upload --release=stable \"$(find dist -maxdepth 1 -type f -name '*.snap')\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Artem Nechunaev <artem@nechunaev.com>",
  "license": "MIT",
  "description": "Unofficial Notion desktop client made with Electron for Linux",
  "repository": {
    "type": "git",
    "url": "https://github.com/anechunaev/notion-electron",
    "owner": "anechunaev",
    "name": "notion-electron",
    "project": "notion-electron"
  },
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@clebert/node-d-bus": "^1.0.0",
    "@jimp/core": "^1.6.1",
    "@jimp/js-png": "^1.6.1",
    "@jimp/plugin-resize": "^1.6.1",
    "d-bus-message-protocol": "^1.0.0",
    "d-bus-type-system": "^1.0.0",
    "decode-ico": "^0.4.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "sharp": "^0.34.5",
    "sortablejs": "^1.15.7"
  },
  "dbus": {
    "name": "io.github.anechunaev.NotionElectron",
    "path": "/io/github/anechunaev/NotionElectron",
    "interface": "io.github.anechunaev.NotionElectron"
  },
  "build": {
    "appId": "io.github.anechunaev.NotionElectron",
    "productName": "Notion Electron",
    "executableName": "notion-electron",
    "linux": {
      "target": [
        "rpm",
        "deb",
        "AppImage"
      ],
      "icon": "./assets/icons/desktop.png",
      "desktop": {
        "entry": {
          "Name": "Notion Electron",
          "Icon": "notion-electron",
          "StartupWMClass": "notion-electron",
          "Terminal": "false",
          "Type": "Application",
          "Categories": "Utility;Office;",
          "Actions": "Options;Updates;About;"
        },
        "desktopActions": {
          "Options": {
            "Name": "Options",
            "Exec": "dbus-send --session --type=signal --dest=io.github.anechunaev.NotionElectron /io/github/anechunaev/NotionElectron io.github.anechunaev.NotionElectron.Options"
          },
          "Updates": {
            "Name": "Updates",
            "Exec": "dbus-send --session --type=signal --dest=io.github.anechunaev.NotionElectron /io/github/anechunaev/NotionElectron io.github.anechunaev.NotionElectron.Updates"
          },
          "About": {
            "Name": "About",
            "Exec": "dbus-send --session --type=signal --dest=io.github.anechunaev.NotionElectron /io/github/anechunaev/NotionElectron io.github.anechunaev.NotionElectron.About"
          }
        }
      },
      "category": "Utility;Office;"
    },
    "snap": {
      "base": "core24",
      "grade": "stable"
    },
    "artifactName": "Notion_Electron-${version}-${arch}.${ext}",
    "icon": "./assets/icons/desktop.png",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**/*"
    ]
  }
}
